# AI Model Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=...

# Trigger.dev (self-hosted — no cloud account needed)
# See docs/trigger-dev-self-hosted.md for setup instructions
TRIGGER_API_URL=http://localhost:3040
TRIGGER_SECRET_KEY=tr_dev_...  # copy from your local Trigger.dev dashboard

# Notifications — Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_DEFAULT_CHANNEL=#marketing-alerts

# Notifications — Email (SendGrid)
# See docs/sendgrid-setup.md for full configuration guide
SENDGRID_API_KEY=SG....
EMAIL_FROM_ADDRESS=agents@yourdomain.com   # must match your authenticated domain in SendGrid
EMAIL_FROM_NAME=Marketing Agent

# Notifications — Webhook
WEBHOOK_SECRET=your-shared-secret

# Escalation
MARKETER_SLACK_CHANNEL=#marketing-alerts
ADMIN_EMAIL=admin@mapp.com

# MCP Servers (JSON array, optional)
# MCP_SERVERS=[{"name":"analytics","command":"npx","args":["-y","@analytics/mcp-server"]}]

# Server (avoid 3000 — used by Trigger.dev Electric, and 3040 — Trigger.dev dashboard)
PORT=3001
