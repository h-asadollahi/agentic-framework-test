# ─── AI Provider API Keys ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=...

# ─── AI Model Aliases ─────────────────────────────────────────────────
# Map each provider:tier to a concrete model ID (without the provider prefix).
# Changing a model version is a one-line change here — no code edits needed.
# If omitted, sensible defaults are used (see src/config/providers.ts).
#
# Docs: Anthropic  → https://platform.claude.com/docs/en/about-claude/models/overview
#       OpenAI     → https://platform.openai.com/docs/models
#       Google     → https://ai.google.dev/gemini-api/docs/models
MODEL_ANTHROPIC_FAST=claude-haiku-4-5
MODEL_ANTHROPIC_BALANCED=claude-sonnet-4-6
MODEL_ANTHROPIC_POWERFUL=claude-opus-4-6
MODEL_OPENAI_FAST=gpt-4o-mini
MODEL_OPENAI_BALANCED=gpt-4o
MODEL_OPENAI_POWERFUL=gpt-5
MODEL_OPENAI_REASONING=o3
MODEL_GOOGLE_FAST=gemini-2.5-flash
MODEL_GOOGLE_BALANCED=gemini-2.5-pro

# ─── Agent → Model Assignments ────────────────────────────────────────
# Comma-separated list: first value = preferred model, rest = ordered fallbacks.
# Uses alias names from the section above (e.g. "anthropic:fast", "google:balanced").
# If an agent exhausts all models, it triggers human-in-the-loop escalation.
# If omitted, sensible defaults are used (see src/config/models.ts).
AGENT_ORCHESTRATOR_MODELS=openai:powerful,anthropic:powerful,google:balanced
AGENT_GROUNDING_MODELS=openai:fast,anthropic:fast,google:fast
AGENT_COGNITION_MODELS=openai:reasoning,anthropic:balanced,google:balanced
AGENT_AGENCY_MODELS=openai:balanced,anthropic:balanced,google:balanced
AGENT_INTERFACE_MODELS=openai:fast,anthropic:fast,google:fast
AGENT_NOTIFICATION_MANAGER_MODELS=openai:fast,anthropic:fast,google:fast

# ─── Trigger.dev (self-hosted — no cloud account needed) ──────────────
# See docs/trigger-dev-self-hosted.md for setup instructions
TRIGGER_API_URL=http://localhost:3040
TRIGGER_SECRET_KEY=tr_dev_...           # copy from your local Trigger.dev dashboard
TRIGGER_PROJECT_REF=proj_xxxxx          # copy from dashboard → project settings

# ─── Notifications — Slack ────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_USER_OAUTH_TOKEN=xoxp-...
SLACK_ADMIN_HITL_CHANNEL=#brand-cp-admin-hitl
SLACK_ADMIN_MONITORING_CHANNEL=#brand-cp-admin-monitoring
SLACK_MARKETERS_HITL_CHANNEL=#brand-cp-marketers-hitl
SLACK_MARKETERS_MONITORING_CHANNEL=#marketing-team-monitoring

# ─── Notifications — Email (SendGrid) ─────────────────────────────────
# See docs/sendgrid-setup.md for full configuration guide
SENDGRID_API_KEY=SG....
EMAIL_FROM_ADDRESS=agents@yourdomain.com   # must match your authenticated domain in SendGrid
EMAIL_FROM_NAME=Marketing Agent

# ─── Notifications — Webhook ──────────────────────────────────────────
WEBHOOK_SECRET=your-shared-secret

# ─── Escalation ───────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com

# ─── MCP Servers (JSON array, optional) ───────────────────────────────
# MCP_SERVERS=[{"name":"analytics","command":"npx","args":["-y","@analytics/mcp-server"]}]

# ─── MAPP Hosted MCP Server (optional) ─────────────────────────────────
# Auto-mapped to serverName "mapp-michel" used by learned-routes MCP entries
MAPP_MCP_SERVER_MICHEL_URL=
MAPP_MCP_SERVER_MICHEL_TOKEN=

### Mapp Analyticts API:
MAPP_ANALYTICS_API_URL=https://intelligence.eu.mapp.com
MAPP_ANALYTICS_API_CLIENT_ID=...
MAPP_ANALYTICS_API_CLIENT_SECRET=...

# ─── Server ───────────────────────────────────────────────────────────
# Avoid 3000 (Trigger.dev Electric) and 3040 (Trigger.dev dashboard)
PORT=3001
