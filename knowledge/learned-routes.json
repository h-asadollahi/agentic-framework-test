        "args": {
          "queryObject": {
            "columns": [
              {
                "name": "session_id",
                "scope": "OBJECT",
                "context": "SESSION",
                "variant": "NORMAL",
                "lowerLimit": 1,
                "upperLimit": 50
              },
              {
                "name": "pages_pageImpressions",
                "columnPeriod": "ANALYSIS",
                "scope": "OBJECT",
                "context": "PAGE",
                "variant": "NORMAL"
              }
            ],
            "variant": "LIST",
            "predefinedContainer": {
              "filters": [
                {
                  "name": "time_dynamic",
                  "filterPredicate": "LIKE",
                  "connector": "AND",
                  "caseSensitive": false,
                  "context": "NONE",
                  "intern": false,
                  "value1": "last_7_days",
                  "value2": ""
                }
              ],
              "containers": []
            }
          },
          "resultType": "DATA_ONLY"
        }
      },
